# 复制为 .env 后按本机修改（不要提交 .env 到 Git）
#
# 容器内访问宿主机 MySQL：使用主机名 host.docker.internal（Docker Desktop Win/Mac 可用；
# Linux 已在本 compose 中为 api 服务配置 host-gateway 映射）。
#
# 请将 root、密码、库名 news_app 改成与面试官本机 MySQL 一致。

DATABASE_URL=mysql+aiomysql://root:123456@host.docker.internal:3306/news_app?charset=utf8mb4

# 是否在终端打印 SQL，一般 false
SQLALCHEMY_ECHO=false
