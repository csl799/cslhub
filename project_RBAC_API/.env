# 项目基础配置
PROJECT_NAME=FastAPI RBAC Admin System
VERSION=1.0.0
ENVIRONMENT=dev  # dev开发/test测试/prod生产

# 数据库配置
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=root  # 你的MySQL用户名
MYSQL_PASSWORD=123456  # 你的MySQL密码
MYSQL_DATABASE=fastapi_rbac  # 提前创建的数据库名

# JWT配置
JWT_SECRET_KEY=你的自定义随机密钥（用openssl rand -hex 32生成）
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=120  # 访问token过期时间2小时
REFRESH_TOKEN_EXPIRE_DAYS=7  # 刷新token过期时间7天

# Redis配置（限流、缓存用）
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=12214613Ecust#