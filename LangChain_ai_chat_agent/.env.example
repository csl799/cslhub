# CHAT_MODEL=deepseek-chat

# ---------- Checkpoint（本地 MySQL）----------
# 先用可登录 MySQL 的账号填下面两项；库不存在时会自动 CREATE DATABASE
MYSQL_USER=root
MYSQL_PASSWORD=123456

# 可选：库名（仅字母数字下划线），默认 langgraph_checkpoint
# MYSQL_DATABASE=langgraph_checkpoint
# MYSQL_HOST=localhost
# MYSQL_PORT=3306
