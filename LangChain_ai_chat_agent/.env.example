# ---------- 对话模型（按需） ----------
# CHAT_MODEL=deepseek-chat

# ---------- Checkpoint（本地 MySQL）----------
# 先用可登录 MySQL 的账号填下面两项；库不存在时会自动 CREATE DATABASE
#MYSQL_USER=
#MYSQL_PASSWORD=

# 可选：库名（仅字母数字下划线），默认 langgraph_checkpoint
# MYSQL_DATABASE=langgraph_checkpoint
# MYSQL_HOST=localhost
# MYSQL_PORT=3306

# ---------- Tavily 联网搜索 ----------
# TAVILY_API_KEY=

# ---------- 登录 JWT ----------
# JWT_SECRET_KEY=请填写足够长的随机字符串
# JWT_EXPIRE_HOURS=168
